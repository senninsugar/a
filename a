<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verification - Security Check</title>
    <style>
        :root {
            --primary-blue: #0051c3;
            --bg-gray: #fafafa;
            --text-main: #313131;
            --widget-border: #e0e0e0;
        }

        body {
            font-family: -apple-system, system-ui, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background-color: var(--bg-gray);
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
            color: var(--text-main);
        }

        .verify-container {
            background: white;
            padding: 40px;
            border-radius: 4px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            width: 100%;
            max-width: 450px;
            text-align: left;
        }

        h1 { font-size: 28px; margin-bottom: 8px; font-weight: 500; }
        p { font-size: 15px; color: #666; margin-bottom: 30px; line-height: 1.5; }

        .cf-widget {
            border: 1px solid var(--widget-border);
            border-radius: 3px;
            padding: 15px 20px;
            display: flex;
            align-items: center;
            background: #fff;
            cursor: pointer;
            transition: border-color 0.2s;
            user-select: none;
            position: relative;
        }
        .cf-widget:hover { border-color: #ccc; }

        .checkbox-wrapper {
            width: 28px;
            height: 28px;
            border: 2px solid #ddd;
            border-radius: 4px;
            margin-right: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        .spinner {
            width: 18px;
            height: 18px;
            border: 2px solid var(--primary-blue);
            border-top: 2px solid transparent;
            border-radius: 50%;
            display: none;
            animation: spin 0.8s linear infinite;
        }

        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

        .check-mark {
            display: none;
            color: var(--primary-blue);
            font-weight: bold;
            font-size: 20px;
        }

        .status-text { font-size: 14px; font-weight: 400; flex-grow: 1; }

        .custom-logo {
            width: 24px;
            height: 24px;
            fill: #888;
        }

        .hidden-trap { opacity: 0; position: absolute; left: -9999px; }

        #success-msg {
            margin-top: 20px;
            color: #2e7d32;
            font-weight: bold;
            display: none;
            text-align: center;
        }

        #fail-msg {
            margin-top: 20px;
            color: #d32f2f;
            font-weight: bold;
            display: none;
            background: #fff5f5;
            padding: 10px;
            border-radius: 4px;
            border: 1px solid #ffcdd2;
        }
    </style>
</head>
<body>

<div class="verify-container">
    <h1>認証が必要です</h1>
    <p>次に進む前に、あなたが人間であることを確認します。</p>

    <input type="text" class="hidden-trap" id="bot_trap" tabindex="-1" autocomplete="off">

    <div class="cf-widget" id="verify-box">
        <div class="checkbox-wrapper" id="box-ui">
            <div class="spinner" id="loader"></div>
            <div class="check-mark" id="check">✓</div>
        </div>
        <div class="status-text" id="status">クリックして確認</div>
        
        <svg class="custom-logo" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/vue">
            <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm0 10.99h7c-.47 4.34-3.1 8.25-7 9.49v-9.49H5V6.3l7-3.11v7.8z"/>
        </svg>
    </div>

    <div id="success-msg">検証が成功しました。</div>
    <div id="fail-msg">検証に失敗しました。不適切なアクセス経路（プロキシ等）の可能性があります。</div>
</div>

<script>
class SecureDetector {
    constructor() {
        this.startTime = Date.now();
        this.interacted = false;
        this.isVerifying = false;
        this.activityCount = 0;

        const events = ['mousemove', 'keydown', 'scroll', 'touchstart', 'mousedown'];
        events.forEach(e => {
            window.addEventListener(e, () => { 
                this.interacted = true; 
                this.activityCount++;
            }, { passive: true });
        });
    }

    async verify() {
        if (this.isVerifying) return;
        this.isVerifying = true;

        document.getElementById('loader').style.display = 'block';
        document.getElementById('status').innerText = '検証中...';

        // 演出用の待機時間を最小限（10ms）に設定し、即座に実測判定を開始
        await new Promise(resolve => setTimeout(resolve, 10));

        let score = 0;
        let reasons = [];
        
        // 1. Honeypot
        if (document.getElementById('bot_trap').value !== "") {
            score += 100;
            reasons.push("Honeypot");
        }
        
        // 2. WebDriver
        if (navigator.webdriver) {
            score += 100;
            reasons.push("WebDriver");
        }
        
        // 3. 滞在時間
        const timeElapsed = (Date.now() - this.startTime) / 1000;
        if (timeElapsed < 1.5) {
            score += 30;
            reasons.push("Fast");
        }
        
        // 4. 挙動
        if (!this.interacted || this.activityCount < 2) {
            score += 30;
            reasons.push("No interaction");
        }

        // 5. 画面解像度
        if (window.innerWidth < 100 || window.innerHeight < 100) {
            score += 100;
            reasons.push("Hidden window");
        }

        // 6. ユーザーエージェントの矛盾
        if (/HeadlessChrome/.test(navigator.userAgent)) {
            score += 100;
            reasons.push("Headless browser");
        }

        // 7. プラグインの有無
        if (navigator.plugins && navigator.plugins.length === 0 && !('ontouchstart' in window)) {
            score += 40;
            reasons.push("No plugins");
        }

        // 8. 自動操作プロパティの検出
        const botProps = ['__webdriver_evaluate', '__selenium_evaluate', '__webdriver_script_fn', 'cdc_adoQ80914912183181_Array', 'cdc_adoQ80914912183181_Promise'];
        if (botProps.some(prop => window[prop] || document[prop])) {
            score += 100;
            reasons.push("Bot properties detected");
        }

        // 9. 言語設定とタイムゾーンの矛盾
        const tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
        const lang = navigator.language;
        if (lang.startsWith('ja') && tz !== 'Asia/Tokyo') {
            score += 50; 
            reasons.push("Location/Timezone mismatch");
        }

        // 10. インターネット接続プロパティの確認
        if (window.opera || navigator.appName === 'Microsoft Internet Explorer') {
            if (!/Trident|MSIE|Opera/.test(navigator.userAgent)) {
                score += 80;
                reasons.push("Connection property anomaly");
            }
        }

        // 11. WebRTCによるローカルIP漏洩チェックの痕跡
        if (window.RTCPeerConnection === null) {
            score += 60;
            reasons.push("WebRTC disabled/hidden");
        }

        // --- 高度なWebプロキシ（Ultraviolet/Rammerhead等）の包括的検知 ---

        // 12. グローバル変数のシグネチャ検知
        const proxyProps = [
            '__uv', '__uv_config', '__uv$location',                       // Ultraviolet
            '__RH_GLOBAL_STATE', 'rammerhead_script_injected',           // Rammerhead
            '__womhole_config',                                          // Womhole
            '__alloy_url',                                               // Alloy
            '$host_url'                                                  // Generic Proxies
        ];
        if (proxyProps.some(prop => window[prop] !== undefined)) {
            score += 100;
            reasons.push("Web proxy global detected");
        }

        // 13. ネイティブ関数の汚染チェック (プロキシはこれらを書き換える)
        const isNative = (fn) => /\{\s*\[native code\]\s*\}/.test(Function.prototype.toString.call(fn));
        if (!isNative(fetch) || !isNative(XMLHttpRequest.prototype.open) || !isNative(Object.getOwnPropertyDescriptor)) {
            score += 100;
            reasons.push("Native function hook detected");
        }

        // 14. サービスワーカーとURL構造の相関
        if ('serviceWorker' in navigator) {
            const path = window.location.pathname;
            if (path.includes('/uv/') || path.includes('/proxy/') || path.includes('/sw/')) {
                score += 60;
                reasons.push("Proxy path suspect");
            }
        }

        // 15. Cross-Originの不一致
        try {
            if (window.self !== window.top && !reasons.includes("Hidden window")) {
                score += 40;
                reasons.push("Iframe nesting");
            }
        } catch(e) {}

        // ------------------------------

        document.getElementById('loader').style.display = 'none';

        if (score < 60) {
            document.getElementById('check').style.display = 'block';
            document.getElementById('status').innerText = '検証成功';
            document.getElementById('success-msg').style.display = 'block';
            document.getElementById('verify-box').style.pointerEvents = 'none';
            document.getElementById('box-ui').style.background = '#e8f0fe';
            document.getElementById('fail-msg').style.display = 'none';
            
            // home.html へのリダイレクト処理
            window.location.href = 'home.html';
        } else {
            document.getElementById('status').innerText = '検証失敗';
            document.getElementById('fail-msg').style.display = 'block';
            console.warn("Detection Reasons:", reasons);
        }
    }
}

const detector = new SecureDetector();
document.getElementById('verify-box').addEventListener('click', () => {
    detector.verify();
});
</script>

</body>
</html>
